# ─────────────────────────────────────────────────────────────────────────
# Picsou frontend — Vite environment
#
# Copy to `.env.local` and adjust. All values are optional; the defaults
# below match a standard local dev setup (Vite on :5173, backend on :8080).
# ─────────────────────────────────────────────────────────────────────────

# Demo mode: when "true", the app serves mock data via the demo interceptor
# and never calls the real backend. Used for the public demo build.
VITE_DEMO_MODE=false

# Dev-server proxy target for /api/* (see vite.config.ts). Point this at the
# backend when it does not run on the default host:port.
VITE_API_TARGET=http://localhost:8080
